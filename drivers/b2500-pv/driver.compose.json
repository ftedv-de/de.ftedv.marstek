{
  "id": "b2500-pv",
  "name": {
    "en": "Marstek B2500 PV"
  },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "measure_power.pv1",
    "measure_power.pv2",
    "meter_power"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "title": {
        "en": "PV Power",
        "de": "PV-Leistung"
      }
    },
    "measure_power.pv1": {
      "title": {
        "en": "PV 1 Power",
        "de": "PV 1 Leistung"
      }
    },
    "measure_power.pv2": {
      "title": {
        "en": "PV 2 Power",
        "de": "PV 2 Leistung"
      }
    },
    "meter_power": {
      "title": {
        "en": "PV Energy",
        "de": "PV-Energie"
      },
      "decimals": 3,
      "energy": {
        "cumulative": true,
        "meterType": "daily"
      }
    }
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "start"
    }
  ],
  "settings": [
    {
      "id": "protocol_version",
      "type": "text",
      "label": {
        "en": "Protocol version",
        "de": "Protokollversion"
      },
      "value": "v2"
    },
    {
      "id": "mqtt_state_topic",
      "type": "text",
      "label": {
        "en": "MQTT state topic",
        "de": "MQTT Status-Topic"
      },
      "value": ""
    },
    {
      "id": "mqtt_command_topic",
      "type": "text",
      "label": {
        "en": "MQTT command topic",
        "de": "MQTT Command-Topic"
      },
      "value": ""
    }
  ]
}
