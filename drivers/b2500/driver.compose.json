{
  "id": "b2500",
  "name": {
    "en": "Marstek B2500"
  },
  "class": "battery",
  "capabilities": [
    "measure_battery",
    "measure_power",
    "target_power",
    "target_power_mode",
    "meter_power.charged",
    "meter_power.discharged",
    "b2500_available_energy",
    "marstek_output1_power",
    "marstek_output2_power",
    "marstek_dod",
    "marstek_threshold_w",
    "marstek_firmware_version",
    "marstek_wifi_signal",
    "marstek_cell_temp_min",
    "marstek_cell_temp_max",
    "marstek_output1_enabled",
    "marstek_output2_enabled"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "title": {
        "en": "Output Power",
        "de": "Ausgangsleistung"
      }
    },
    "target_power": {
      "min": -800,
      "max": 0,
      "step": 10,
      "decimals": 0
    },
    "meter_power.charged": {
      "title": {
        "en": "Charged Energy",
        "de": "Geladene Energie"
      },
      "decimals": 3,
      "energy": {
        "cumulative": true,
        "meterType": "daily"
      }
    },
    "meter_power.discharged": {
      "title": {
        "en": "Discharged Energy",
        "de": "Entladene Energie"
      },
      "decimals": 3,
      "energy": {
        "cumulative": true,
        "meterType": "daily"
      }
    }
  },
  "energy": {
    "homeBattery": true,
    "meterPowerImportedCapability": "meter_power.charged",
    "meterPowerExportedCapability": "meter_power.discharged"
  },
  "platforms": [
    "local"
  ],
  "connectivity": [
    "lan"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "start"
    }
  ],
  "repair": [
    {
      "id": "schedules"
    }
  ],
  "settings": [
    {
      "id": "protocol_version",
      "type": "text",
      "label": {
        "en": "Protocol version",
        "de": "Protokollversion"
      },
      "value": "v2"
    },
    {
      "id": "mqtt_state_topic",
      "type": "text",
      "label": {
        "en": "MQTT state topic",
        "de": "MQTT Status-Topic"
      },
      "value": ""
    },
    {
      "id": "mqtt_command_topic",
      "type": "text",
      "label": {
        "en": "MQTT command topic",
        "de": "MQTT Command-Topic"
      },
      "value": ""
    },
    {
      "id": "polling_interval_seconds",
      "type": "number",
      "label": {
        "en": "Polling interval",
        "de": "Polling-Intervall"
      },
      "hint": {
        "en": "Status polling interval in seconds. Set to 0 to disable automatic polling.",
        "de": "Status-Polling-Intervall in Sekunden. 0 deaktiviert das automatische Polling."
      },
      "value": 60,
      "min": 0,
      "max": 3600,
      "step": 5,
      "units": {
        "en": "seconds",
        "de": "Sekunden"
      }
    }
  ]
}
