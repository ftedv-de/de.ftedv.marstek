  "capabilitiesOptions": {
    "measure_power": {
      "title": {
        "en": "Net Battery Power",
        "de": "Netto-Batterieleistung"
      }
    },
    "target_power": {
      "min": -800,
      "max": 0,
      "step": 10,
      "decimals": 0
    },
